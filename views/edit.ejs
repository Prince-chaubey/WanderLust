<% layout("/layouts/boilerplate.ejs")%>
<body class="bg-gray-100 text-gray-900">

    <div class="max-w-3xl mx-auto mt-10 bg-white shadow-lg rounded-lg p-6 md:p-8">
        <h2 class="text-3xl md:text-4xl font-bold text-center text-indigo-600 mb-6">Create a New listing</h2>

        <form action="/listings/<%= listing._id %>?_method=PUT" method="post" class="space-y-6">
            <input type="hidden" name="_method" value="PUT">
            <!-- Title -->
            <div>
                <label class="block text-lg font-semibold mb-1">Title</label>
                <input type="text" name="title" value="<%=listing.title%>" placeholder="Enter title" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400 text-gray-600 font-medium">
            </div>

            <!-- Description -->
            <div>
                <label class="block text-lg font-semibold mb-1">Description</label>
                <textarea name="description" rows="3"  placeholder="Enter description" required "
                          class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400 text-gray-600 font-medium">
                          <%=listing.description%>
                        </textarea>
            </div>

            <!-- Image URL -->
            <div>
                <label class="block text-lg font-semibold mb-1">Image URL</label>
                <input type="url" name="image" placeholder="Enter image URL" required value="<%=listing.image%>"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400 text-gray-600 font-medium">
            </div>

            <!-- Price -->
            <div>
                <label class="block text-lg font-semibold mb-1">Price</label>
                <input type="number" name="price" placeholder="Enter price" required value="<%=listing.price%>"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400 text-gray-600 font-medium">
            </div>

            <!-- Location -->
            <div>
                <label class="block text-lg font-semibold mb-1">Location</label>
                <input type="text" name="location" placeholder="Enter location" required value="<%=listing.location%>"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400 text-gray-600 font-medium">
            </div>

            <!-- Country -->
            <div>
                <label class="block text-lg font-semibold mb-1">Country</label>
                <input type="text" name="country" placeholder="Enter country" required value="<%=listing.country%>"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400 text-gray-600 font-medium">
            </div>

            <!-- Submit Button -->
            <div class="flex flex-col md:flex-row justify-center gap-4 mt-6">
                <button type="submit"
                        class="w-full md:w-auto bg-indigo-600 text-white px-6 py-2 rounded-md text-lg font-semibold hover:bg-indigo-700 transition duration-300">
                    Submit listing
                </button>
                <a href="/listings"
                   class="w-full md:w-auto text-center bg-gray-500 text-white px-6 py-2 rounded-md text-lg font-semibold hover:bg-gray-600 transition duration-300">
                    Cancel
                </a>
            </div>
        </form>
    </div>

</body>

