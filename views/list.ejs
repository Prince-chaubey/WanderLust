<% layout("/layouts/boilerplate.ejs")%>
<body class="bg-gray-100 text-gray-900">

    <div class="container mx-auto p-6">
        <div class="max-w-3xl mx-auto bg-white shadow-lg rounded-lg p-6">
            <!-- Listing Title -->
            <h3 class="text-3xl md:text-4xl font-bold text-center text-indigo-600 mb-6">
                <%= listings.title %>
            </h3>

            <!-- Image Display -->
            <div class="flex justify-center">
                <img src="<%= listings.image %>" alt="<%= listings.title %>" 
                     class="w-full md:w-3/4 h-64 object-cover rounded-lg shadow-md mb-4">
            </div>

            <!-- Listing Details -->
            <div class="space-y-4 text-lg text-gray-700">
                <p><span class="font-semibold text-gray-900">Description:</span> <%= listings.description %></p>
                <p><span class="font-semibold text-gray-900">Location:</span> <%= listings.location %></p>
                <p><span class="font-semibold text-gray-900">Country:</span> <%= listings.country %></p>
                <p><span class="font-semibold text-gray-900">Price: &#x20b9;</span> 
                    <%= listings.price ? listings.price.toLocaleString("en-IN") : "N/A" %>
                </p>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row justify-center gap-4 mt-6">
                <a href="/listings" 
                   class="w-full sm:w-auto text-center bg-indigo-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-indigo-700 transition duration-300">
                    Back to Listings
                </a>
                <form action="/listings/<%=listings._id%>/edit" method="get">
                      <button class="w-full sm:w-auto text-center bg-yellow-500 text-white px-6 py-2 rounded-lg font-medium hover:bg-yellow-600 transition duration-300" >
                        Edit
                      </button>">
                </form>
                
            </div>
        </div>
    </div>

</body>