<% layout("/layouts/boilerplate.ejs")%>
<body class="bg-gray-100 text-gray-900">

    <div class="container mx-auto p-6">
        <h2 class="text-3xl md:text-4xl font-bold text-center text-indigo-600 mb-6">All Listings</h2>

        <!-- Responsive Grid Layout for Listings -->
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 px-6">
            <% for(let list of listings) { %>
                <div class="bg-white shadow-lg rounded-lg overflow-hidden transition-transform transform hover:scale-105 duration-300 cursor-pointer">
                    <img src="<%= list.image %>" alt="<%= list.title %>" class="w-full h-48 object-cover">

                    <div class="p-4">
                        <h3 class="text-lg font-semibold">
                            <a href="/listings/<%= list._id %>" class="text-indigo-600 hover:text-indigo-800 transition duration-300">
                                <%= list.title %>
                            </a>
                        </h3>
                        <p class="text-gray-600"><%= list.location %>, <%= list.country %></p>
                        <p class="text-indigo-500 font-bold">$<%= list.price %></p>

                        <div class="flex flex-col sm:flex-row gap-2 justify-center items-center mt-4">
                            <a href="/listings/<%= list._id %>" 
                               class="w-full sm:w-auto text-center bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 transition duration-300 font-medium">
                                View Details
                            </a>

                            <form action="/listings/<%=list._id%>?_method=DELETE" method="POST" 
                                  onsubmit="return confirm('Are you sure you want to delete this listing?');">
                                <button type="submit" 
                                        class="w-full sm:w-auto bg-red-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-red-700 transition duration-300">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- Create New Listing -->
        <div class="flex flex-col sm:flex-row justify-center gap-4 mt-8">
            <form action="/listings/new" method="get">
                <button type="submit" 
                        class="w-full sm:w-auto bg-green-600 text-white px-6 py-2 rounded-lg text-lg font-semibold hover:bg-green-700 transition duration-300">
                    + Create New Listing
                </button>
            </form>
        </div>

    </div>

</body>
